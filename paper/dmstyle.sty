% ============================================================================
% dmstyle.sty — clean single-column technical-report style.
%
% Aesthetic inspired by modern AI-lab technical reports (Google DeepMind,
% Anthropic, OpenAI): Times-like serif body, Helvetica-like bold sans-serif
% section headings, generous-but-dense single column, muted link colours,
% a clean centered title block. This is an independent look-alike, NOT the
% (non-public) official DeepMind LaTeX class.
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{dmstyle}[2026/06/15 v1 clean single-column tech-report style]

% ── Fonts ──────────────────────────────────────────────────────────────────
\RequirePackage[T1]{fontenc}
\RequirePackage{mathptmx}                 % Times-like serif body + math
\RequirePackage[scaled=0.90]{helvet}      % Helvetica-like sans for headings
\RequirePackage[protrusion=true,expansion=false]{microtype}

% ── Page geometry ────────────────────────────────────────────────────────────
\RequirePackage[letterpaper,margin=1in,headsep=12pt,footskip=26pt]{geometry}
\linespread{1.04}                          % a touch of leading for readability

% ── Colours ──────────────────────────────────────────────────────────────────
\RequirePackage{xcolor}
\definecolor{dmink}{HTML}{1A1A1A}          % near-black for headings
\definecolor{dmblue}{HTML}{1A56C4}         % muted link/citation blue
\definecolor{dmgray}{HTML}{5F6368}         % affiliation / secondary text
\definecolor{dmrule}{HTML}{D0D0D0}         % hairline rules

% ── Section headings: bold sans, tight spacing ───────────────────────────────
\RequirePackage{titlesec}
\titleformat{\section}
  {\sffamily\large\bfseries\color{dmink}}{\thesection}{0.7em}{}
\titleformat{\subsection}
  {\sffamily\normalsize\bfseries\color{dmink}}{\thesubsection}{0.6em}{}
\titleformat{\subsubsection}
  {\sffamily\small\bfseries\color{dmink}}{\thesubsubsection}{0.5em}{}
\titlespacing*{\section}     {0pt}{13pt plus 2pt minus 2pt}{5pt}
\titlespacing*{\subsection}  {0pt}{10pt plus 2pt minus 2pt}{4pt}
\titlespacing*{\subsubsection}{0pt}{8pt plus 1pt minus 1pt}{3pt}

% ── Captions: small, sans bold label ─────────────────────────────────────────
\RequirePackage[font=small,labelfont={sf,bf},labelsep=period,
                textfont=rm,skip=6pt]{caption}

% ── Running header / footer ──────────────────────────────────────────────────
\RequirePackage{fancyhdr}
\newcommand{\dmrunningtitle}{}
\newcommand{\setrunningtitle}[1]{\renewcommand{\dmrunningtitle}{#1}}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[L]{\footnotesize\sffamily\color{dmgray}\dmrunningtitle}
\fancyfoot[C]{\footnotesize\sffamily\color{dmgray}\thepage}
\fancypagestyle{plain}{%
  \fancyhf{}\renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\footnotesize\sffamily\color{dmgray}\thepage}}

% ── Title block ──────────────────────────────────────────────────────────────
% \dmtitle, \dmauthor, \dmaffil, \dmdate then \dmmaketitle.
\newcommand{\dmtitlestr}{}\newcommand{\dmtitle}[1]{\renewcommand{\dmtitlestr}{#1}}
\newcommand{\dmauthorstr}{}\newcommand{\dmauthor}[1]{\renewcommand{\dmauthorstr}{#1}}
\newcommand{\dmaffilstr}{}\newcommand{\dmaffil}[1]{\renewcommand{\dmaffilstr}{#1}}
\newcommand{\dmdatestr}{}\newcommand{\dmdate}[1]{\renewcommand{\dmdatestr}{#1}}
\newcommand{\dmmaketitle}{%
  \thispagestyle{plain}%
  \begin{center}
    {\sffamily\bfseries\fontsize{20}{24}\selectfont\color{dmink}\dmtitlestr\par}
    \vspace{1.1em}
    {\large\dmauthorstr\par}
    \ifx\dmaffilstr\empty\else\vspace{0.35em}{\color{dmgray}\dmaffilstr\par}\fi
    \ifx\dmdatestr\empty\else\vspace{0.35em}{\color{dmgray}\dmdatestr\par}\fi
  \end{center}
  \vspace{0.6em}
}

% ── Abstract: narrowed block with a sans label and hairline rules ────────────
\renewenvironment{abstract}{%
  \begin{center}\begin{minipage}{0.90\textwidth}
  {\color{dmrule}\hrule height 0.6pt}\vspace{6pt}
  {\noindent\sffamily\bfseries\color{dmink}\abstractname}\par\vspace{3pt}
  \small\noindent\ignorespaces
}{%
  \par\vspace{6pt}{\color{dmrule}\hrule height 0.6pt}
  \end{minipage}\end{center}\vspace{0.8em}
}

% NOTE: hyperref is loaded by the main document AFTER natbib (load order
% matters); it uses the dmblue colour defined above.

\endinput
