# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
*.lof
*.lot
*.nav
*.snm
*.vrb
*.brf

# Editor/OS
.DS_Store
*.swp
*~

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Probe run outputs (re-generated by run_probe.py)
outputs/

# Experiment scratch: large regenerable probe dumps + run monitors/sentinels.
# The derived CSVs/summaries/READMEs under experiments/ ARE tracked; only the
# raw per-(entity,model) probe dumps and run-orchestration scratch are not.
experiments/**/pilot_results*.json
experiments/**/ALL_DONE
experiments/**/*_done
experiments/**/monitor*
experiments/**/watcher_state.md
experiments/**/log_*.txt

# Local dev
.envrc
.venv/
node_modules/

# Explainer site build output (source + generated data assets ARE tracked)
site/dist/

# t4_1 news-events: derived outputs ARE tracked (overrides the global
# `outputs/` rule above); the raw probe dump stays ignored via the
# experiments/**/pilot_results*.json rule.
!experiments/t4_1_news_events/outputs/

# t5_2 attention baseline: derived outputs ARE tracked (same override
# pattern as t4_1; ~60KB of pageview counts + summary stats).
!experiments/t5_2_attention_baseline/outputs/

# t5_4 self-report: pairwise verdicts + derived outputs ARE tracked (same
# override pattern; pairwise_results.json is the primary data analyze.py
# consumes — 2.5MB of verdicts, not a raw probe dump). Logs stay out.
!experiments/t5_4_self_report/outputs/
experiments/t5_4_self_report/outputs/*.log

# t6_v2_protocol: ship ONLY the compressed record-level source of truth
# (recognition_final + zh_results, ~13MB gzipped) that build_release_tables.py
# and the paper reproduce from. The uncompressed .jsonl (63MB/5MB) stay ignored
# via the `outputs/` rule; everything else under outputs/ stays ignored too.
!experiments/t6_v2_protocol/outputs/
experiments/t6_v2_protocol/outputs/*
!experiments/t6_v2_protocol/outputs/recognition_final.jsonl.gz
!experiments/t6_v2_protocol/outputs/zh_results.jsonl.gz

# Regenerable figure preview rasters (the paper embeds the .pdf, not the .png)
paper/figures/*.png
# Scratch/backup input artifacts
experiments/**/*.bak.json
experiments/**/*.PREFIX.*

# arXiv submission tarball (build artifact)
paper/arxiv.tar.gz
